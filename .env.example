# DMM Affiliate API（NEXT_PUBLIC_ を付けないこと）
DMM_API_ID=your_api_id_here
DMM_AFFILIATE_ID=your_affiliate_id_990

# Supabase（公開キーは NEXT_PUBLIC_ OK、RLS で保護）
# 取得元: Supabase Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# X API（サーバー専用）
# 本番は: wrangler secret put X_API_KEY
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
