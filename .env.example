# DMM Affiliate API（NEXT_PUBLIC_ を付けないこと）
DMM_API_ID=your_api_id_here
DMM_AFFILIATE_ID=your_affiliate_id_990

# Supabase（公開キーは NEXT_PUBLIC_ OK、RLS で保護）
# 取得元: Supabase Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# トップページ ISR 再生成用（daily-revalidate Worker から呼ばれる）
# openssl rand -hex 32 で生成する
REVALIDATE_SECRET=
# デプロイ先 URL（Cloudflare Pages の本番 URL）
# SITE_URL=https://your-site.pages.dev

# VAPID（Web Push）
# 生成コマンド: node scripts/generate-vapid-keys.mjs
# NEXT_PUBLIC_VAPID_PUBLIC_KEY はブラウザで購読時に使用するため NEXT_PUBLIC_ 必須
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY_JWK は Workers のみで使用（wrangler secret put VAPID_PRIVATE_KEY_JWK）
# VAPID_SUBJECT は通知管理者の連絡先（mailto: または https:）
# VAPID_SUBJECT=mailto:your@email.com

# KPI ダッシュボード（/admin/kpi）を閲覧できる管理者のメールアドレス（追加17）
# 未設定だと /admin/kpi は 404（自分のみ閲覧の二重ガード）。本番は wrangler secret put ADMIN_EMAIL
ADMIN_EMAIL=

# Telegram セール速報チャンネル配信（Phase 2 / 追加11）
# 両方未設定なら Telegram 配信は no-op（他チャネルは継続）。本番は wrangler secret put で登録
# TELEGRAM_BOT_TOKEN  : BotFather（@BotFather）で /newbot して発行されるトークン
# TELEGRAM_CHANNEL_ID : 投稿先。公開チャンネルは @channelusername、非公開は -100xxxxxxxxxx
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
