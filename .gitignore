# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/tests/screenshots

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# Cloudflare / opennextjs build output
/.open-next/
/.wrangler/

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local settings (contains sensitive tokens)
.claude/
.mcp.json

# Serena AI assistant
.serena/

# Local verification artifacts under scripts/ (logs / screenshots / throwaway scripts)
/scripts/*.log
/scripts/*.png
/scripts/preview-log.txt
/scripts/verify-*.mjs
/scripts/check-top*.mjs
# Build artifact: regenerated each build by scripts/patch-worker.js (BUILD_ID churns)
/scripts/load-manifest-stub.js
.mcp.json
